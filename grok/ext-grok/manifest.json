{
  "manifest_version": 3,
  "name": "Grok Edu Reg",
  "version": "1.2.0",
  "description": "B1 edu mail → B2 xAI fill. Step nhớ storage.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://api.getedumail.com/*",
    "https://getedumail.com/*",
    "https://*.getedumail.com/*",
    "https://accounts.x.ai/*",
    "https://*.x.ai/*",
    "http://127.0.0.1:3847/*",
    "http://localhost:3847/*"
  ],
  "action": {
    "default_title": "Grok Edu Reg",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://accounts.x.ai/*", "https://*.x.ai/*"],
      "js": ["content-shared.js", "content-xai.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://getedumail.com/*", "https://*.getedumail.com/*"],
      "js": ["content-shared.js", "content-edu.js"],
      "run_at": "document_idle"
    }
  ]
}
