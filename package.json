{
  "name": "getedumail-tools",
  "private": true,
  "type": "module",
  "scripts": {
    "edu": "node mail/getedumail-menu.mjs",
    "edu:create": "node mail/getedumail-auto.mjs --no-open",
    "edu:login": "node mail/getedumail-auto.mjs --login",
    "edu:batch": "node mail/getedumail-auto.mjs --count 3 --no-open",
    "grok:menu": "node grok/grok-menu.mjs",
    "byesu:menu": "node byesu/byesu-menu.mjs",
    "byesu": "node byesu/reg-byesu.mjs --yes",
    "byesu:cdp": "node byesu/reg-byesu.mjs --yes",
    "byesu:multi": "node byesu/reg-multi.mjs",
    "byesu:test-keys": "node byesu/test-keys.mjs",
    "grok": "node grok/reg-grok.mjs --user-chrome --yes",
    "grok:fresh": "node grok/reg-grok.mjs --fresh --user-chrome --yes",
    "grok:reuse": "node grok/reg-grok.mjs --reuse --user-chrome --yes",
    "grok:user": "node grok/reg-grok.mjs --fresh --user-chrome --yes",
    "grok:user:reuse": "node grok/reg-grok.mjs --reuse --user-chrome --yes",
    "grok:multi": "node grok/reg-multi.mjs",
    "proxy:test": "node grok/proxy.mjs --test",
    "proxy:pick": "node grok/proxy.mjs --pick",
    "9r:ping": "node grok/nine-router-auth.mjs --ping",
    "9r:device": "node grok/nine-router-auth.mjs --device --wait --push"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  }
}
